# ------------------------------------------------------------
# 音源ファイルをアーカイブ（.rpa）にまとめる設定
# 対象：
#   game/audio/bgm/
#   game/audio/se/
#   game/audio/voice/ 以下すべて
# ※ 本来、この記述は game/options.rpy に入れることが多いそうです。今回は保守目的で別ファイルに分けました。
# ------------------------------------------------------------

init python:
    # --------------------------------------------------------
    # 1) audio フォルダ以下の音源をすべて "audio" グループに分類
    # --------------------------------------------------------
    # ** は再帰的（サブフォルダ含む）指定
    # voice/a, voice/b などもすべて対象になります
    build.classify("game/audio/**.mp3", "audio")

    # もし ogg / wav を使っている場合は、必要に応じて追加
    # build.classify("game/audio/**.ogg", "audio")
    # build.classify("game/audio/**.wav", "audio")

    # --------------------------------------------------------
    # 2) "audio" アーカイブを作成
    # --------------------------------------------------------
    # ビルド時に audio.rpa のようなファイルにまとめられます
    build.archive("audio", "all")

    # --------------------------------------------------------
    # 補足：
    # ・暗号化ではなくアーカイブ化です
    # ・規約遵守が最優先（同梱OKかどうか）
    # --------------------------------------------------------
